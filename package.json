{
	"name": "@grind-t/bo-nalog",
	"version": "1.0.1",
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"dev": "node --experimental-transform-types --env-file=.env --watch ./playground.ts",
		"typecheck": "tsc --noEmit",
		"lint": "npx @biomejs/biome check --write",
		"test:unit": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.unit.test.ts\"",
		"test:e2e": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.e2e.test.ts\"",
		"test": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.test.ts\"",
		"check": "npm run typecheck && npm run lint && npm run test",
		"build": "tsup",
		"export:companies": "node --experimental-transform-types --env-file-if-exists=.env ./scripts/export/companies.ts",
		"export:bfo": "node --experimental-transform-types ./scripts/export/bfo.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/grind-t/bo-nalog.git"
	},
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/grind-t/bo-nalog/issues"
	},
	"homepage": "https://github.com/grind-t/bo-nalog#readme",
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@grind-t/moex": "^1.0.8",
		"@grind-t/t-invest": "^1.0.0",
		"@microsoft/api-extractor": "latest",
		"@swc/core": "latest",
		"@types/node": "latest",
		"tsup": "latest",
		"typescript": "latest",
		"valibot": "^1.4.1"
	},
	"dependencies": {
		"@grind-t/toolkit": "^2.4.0"
	}
}
